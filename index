<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Plaisir Partagé</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 50px 20px; }
        .btn { 
            display: inline-block; padding: 20px 30px; 
            background: #4F9356; color: white; 
            text-decoration: none; border-radius: 10px; 
            font-size: 1.2em; font-weight: bold;
        }
    </style>
</head>
<body>
    <h2>Ouverture de l'atelier...</h2>
    <p>Cliquez sur le bouton ci-dessous pour voir les détails dans l'application :</p>
    
    <a id="open-link" class="btn" href="#">OUVRIR L'APPLICATION</a>

    <script>
        const params = new URLSearchParams(window.location.search);
        const id = params.get('id');
        // On utilise ici le schéma que tu as défini dans ton AndroidManifest
        const appLink = "plaisirpartage://atelier?id=" + id;

        if (id) {
            document.getElementById('open-link').href = appLink;
            
            // Tentative automatique après 1 seconde
            setTimeout(() => {
                window.location.href = appLink;
            }, 1000);
        } else {
            document.body.innerHTML = "<h2>ID d'atelier manquant</h2>";
        }
    </script>
</body>
</html>
