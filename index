<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Plaisir Partagé</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding-top: 100px; background-color: #f4f4f4; }
        .card { background: white; padding: 30px; border-radius: 15px; display: inline-block; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .btn { 
            display: inline-block; padding: 15px 30px; 
            background: #4F9356; color: white; 
            text-decoration: none; border-radius: 8px; 
            font-weight: bold; margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="card">
        <h2>Atelier trouvé !</h2>
        <p>Cliquez ci-dessous pour l'ouvrir :</p>
        <a id="open-link" class="btn" href="#">VOIR L'ATELIER</a>
    </div>

    <script>
        const params = new URLSearchParams(window.location.search);
        const id = params.get('id');
        if (id) {
            const finalUrl = "plaisirpartage://atelier?id=" + id;
            document.getElementById('open-link').href = finalUrl;
            
            // On tente quand même l'auto-ouverture
            window.location.href = finalUrl;
        } else {
            document.body.innerHTML = "<h1>ID manquant dans le lien</h1>";
        }
    </script>
</body>
</html>
